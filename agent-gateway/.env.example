# Quenyx Agent Gateway (QAG) — default port 9444
QAG_PORT=9444
QAG_HOST=0.0.0.0

# Laravel backend (internal only — agents never call this directly)
BACKEND_BASE_URL=http://127.0.0.1:8000

# Rate limiting
QAG_RATE_LIMIT_WINDOW_MS=60000
QAG_RATE_LIMIT_MAX=120

# Minimum agent version (semver prefix match); empty = no enforcement
QAG_MIN_AGENT_VERSION=

# TLS termination is handled by nginx/reverse proxy in production.
# Agents connect to https://cloud.quenyx.com:9444 (outbound HTTPS only).
