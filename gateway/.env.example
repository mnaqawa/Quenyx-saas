GATEWAY_PORT=4000
BACKEND_BASE_URL=http://127.0.0.1:8000
ENTITLEMENTS_CACHE_TTL_MS=30000
GATEWAY_INTERNAL_SECRET=

# QynSight monitoring runs natively in the Laravel backend (observe:run-checks scheduler).
# There is NO Nagios runtime — the gateway no longer resolves a Nagios binary or container.
# Any /internal/engines/nagios* request returns 410 Gone (see src/engines/index.ts).
