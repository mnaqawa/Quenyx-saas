Default Seed Data (SQL)
-- modules
INSERT INTO modules (name, description, status, created_at, updated_at) VALUES
('Firewall', 'Network firewall protection', 'active', CURRENT_TIMESTAMP, CURRENT_TIMESTAMP),
('Antivirus', 'Malware detection and removal', 'active', CURRENT_TIMESTAMP, CURRENT_TIMESTAMP),
('Intrusion Detection', 'Real-time threat monitoring', 'maintenance', CURRENT_TIMESTAMP, CURRENT_TIMESTAMP);

-- module_subscriptions (links to modules by name)
INSERT INTO module_subscriptions (module_id, subscription_state, created_at, updated_at)
SELECT id, 'active', CURRENT_TIMESTAMP, CURRENT_TIMESTAMP FROM modules WHERE name = 'Firewall';
INSERT INTO module_subscriptions (module_id, subscription_state, created_at, updated_at)
SELECT id, 'trial', CURRENT_TIMESTAMP, CURRENT_TIMESTAMP FROM modules WHERE name = 'Antivirus';
INSERT INTO module_subscriptions (module_id, subscription_state, created_at, updated_at)
SELECT id, 'inactive', CURRENT_TIMESTAMP, CURRENT_TIMESTAMP FROM modules WHERE name = 'Intrusion Detection';

-- users
-- NOTE: password must be a bcrypt hash of "Password123!" (use Laravel's Hash::make).
INSERT INTO users (name, email, password, created_at, updated_at) VALUES
('Quenyx Admin', 'admin@quenyx.test', '<bcrypt_of_Password123!>', CURRENT_TIMESTAMP, CURRENT_TIMESTAMP);

