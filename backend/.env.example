APP_NAME=Quenyx
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

GATEWAY_BASE_URL=http://127.0.0.1:4000
GATEWAY_INTERNAL_SECRET=

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=quenyx_dev
DB_USERNAME=quenyx
DB_PASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
# Production: serve over HTTPS and enable secure cookies.
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax

SEED_ADMIN_PASSWORD=change-me-before-seed

# ----------------------------------------------------------------------------
# GA security hardening (production)
# ----------------------------------------------------------------------------
# CORS: comma-separated allowlist of exact origins. Empty = "*" (DEV ONLY).
# In production set the explicit frontend origin(s).
CORS_ALLOWED_ORIGINS=
# CORS_ALLOWED_ORIGIN_PATTERNS=
CORS_SUPPORTS_CREDENTIALS=false

# Sanctum personal access token lifetime (minutes). Default 7 days.
SANCTUM_TOKEN_EXPIRATION_MINUTES=10080
# SANCTUM_STATEFUL_DOMAINS=app.your-domain.com

# Credential brute-force protection (per-minute attempt ceilings).
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_REGISTER_MAX_ATTEMPTS=10

# Security response headers (App\Http\Middleware\SecurityHeaders).
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
# SECURITY_CSP="default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'"

AGENT_SOURCE_PATH=
AGENT_GO_BINARY=go
AGENT_BUILD_ON_DEMAND=true

# QynSight plugin checks: use PHP CLI (not php-fpm). Example: /usr/bin/php8.2
OBSERVE_PHP_CLI=

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@quenyx.test"
MAIL_FROM_NAME="${APP_NAME}"
