DB_PASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

SEED_ADMIN_PASSWORD=change-me-before-seed

AGENT_SOURCE_PATH=
AGENT_GO_BINARY=go
AGENT_BUILD_ON_DEMAND=true

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
