APP_NAME=Quenyx
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

GATEWAY_BASE_URL=http://127.0.0.1:4000
GATEWAY_INTERNAL_SECRET=

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=quenyx
# Local development: DB_DATABASE=quenyx_dev  (run scripts/mysql-quenyx-setup-dev.sql)
# PHPUnit uses quenyx_test via phpunit.xml — dev/CI only, not on production app servers
DB_USERNAME=quenyx
DB_PASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
# Production: serve over HTTPS and enable secure cookies.
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax

SEED_ADMIN_PASSWORD=change-me-before-seed

# ----------------------------------------------------------------------------
# GA security hardening (production)
# ----------------------------------------------------------------------------
# CORS: comma-separated allowlist of exact origins. Empty = "*" (DEV ONLY).
# In production set the explicit frontend origin(s).
CORS_ALLOWED_ORIGINS=
# CORS_ALLOWED_ORIGIN_PATTERNS=
CORS_SUPPORTS_CREDENTIALS=false

# Sanctum personal access token lifetime (minutes). Default 7 days.
SANCTUM_TOKEN_EXPIRATION_MINUTES=10080
# SANCTUM_STATEFUL_DOMAINS=app.your-domain.com

# Portal login session policy (Bearer PATs — not cookie SESSION_LIFETIME).
# Only one active login per user; a new login invalidates older sessions.
AUTH_SINGLE_SESSION=true
# Close idle sessions after N minutes with no API activity (0 = disabled).
AUTH_IDLE_TIMEOUT_MINUTES=30

# Credential brute-force protection (per-minute attempt ceilings).
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_REGISTER_MAX_ATTEMPTS=10

# Security response headers (App\Http\Middleware\SecurityHeaders).
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
# SECURITY_CSP="default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'"

AGENT_SOURCE_PATH=
# Full path to go binary if not on PATH (e.g. /usr/bin/go)
AGENT_GO_BINARY=go
# Build missing binaries on first download (requires Go + agent/ source on server)
AGENT_BUILD_ON_DEMAND=true
# After deploy, pre-build: php artisan agent:build linux-amd64

# Quenyx Agent Gateway (QAG) — agents connect here, not Laravel directly
AGENT_GATEWAY_PROTOCOL=https
AGENT_GATEWAY_HOST=cloud.quenyx.com
AGENT_GATEWAY_PORT=9444
AGENT_REQUIRE_GATEWAY=true
AGENT_STALE_AFTER_MINUTES=15

# QynSight plugin checks: use PHP CLI (not php-fpm). Example: /usr/bin/php8.2
OBSERVE_PHP_CLI=

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@quenyx.test"
MAIL_FROM_NAME="${APP_NAME}"

# ----------------------------------------------------------------------------
# Quenyx AI — live provider execution (production GA)
# ----------------------------------------------------------------------------
# AI_ENABLED: tri-state. Unset = auto-enable when a real provider (OpenAI key) is configured.
#              true = force live execution when a provider is runnable.
#              false = administrator disabled — chat returns an error, not silent mock (production).
AI_ENABLED=
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Required for Ask Quenyx AI + workspace chat knowledge (File Search):
OPENAI_VECTOR_STORE_ID=
AI_MAX_TOKENS_REASONING=4096
AI_TIMEOUT=180
AI_KNOWLEDGE_TIMEOUT=180
OPENAI_REQUEST_TIMEOUT=180
AI_WORKSPACE_PERSIST_MESSAGES=true
AI_WORKSPACE_KNOWLEDGE_ENABLED=true
OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ORGANIZATION=

# Optional: allow mock in production (emergency only — not for GA).
# AI_MOCK_ALLOWED=false

# Workspace surface (sidebar Quenyx AI). Safe to leave on.
AI_WORKSPACE_ENABLED=true

# Streaming, persistence, and prompt logging (off by default).
# AI_STREAMING_ENABLED=false
# AI_PERSIST_CONVERSATIONS=false
# AI_PROMPT_LOGGING=false

